# ============================================================
# ATLAS Platform — Environment Variables
# Copy to .env and fill values. Never commit .env.
# ============================================================

# --- App ---
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_NAME=atlas-api
APP_VERSION=0.1.0

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=atlas
DB_PASSWORD=atlas_dev_password
DB_DATABASE=atlas_dev
DB_SCHEMA=public
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_LOGGING=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=atlas:

# --- JWT ---
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRY=7d

# --- Event Bus ---
# Options: memory | redis-streams
EVENT_BUS_ADAPTER=memory
EVENT_BUS_STREAM_PREFIX=atlas:events:
EVENT_BUS_CONSUMER_GROUP=atlas-api
EVENT_BUS_MAX_LEN=10000

# --- Audit ---
AUDIT_RETENTION_DAYS=2555
AUDIT_ASYNC=true

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Tenant ---
TENANT_HEADER=x-tenant-id
TENANT_PROVISIONING_TIMEOUT_MS=30000

# --- Observability ---
LOG_LEVEL=debug
LOG_FORMAT=json
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# --- AWS (production) ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REGISTRY=
