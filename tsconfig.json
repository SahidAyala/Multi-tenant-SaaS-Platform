{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@atlas/shared-kernel": ["libs/shared-kernel/src/index.ts"],
      "@atlas/shared-kernel/*": ["libs/shared-kernel/src/*"],
      "@atlas/event-contracts": ["libs/event-contracts/src/index.ts"],
      "@atlas/event-contracts/*": ["libs/event-contracts/src/*"]
    }
  }
}
